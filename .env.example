# ------------------------------------------------------------
# Enterprise VMS - environment template
# Copy to .env.local for dev. In production, set these in
# Vercel (web/kiosk) and Render (api) dashboards. Never commit real secrets.
# ------------------------------------------------------------

# --- Database -----------------------------------------------
# Local: docker-compose Postgres
# Prod:  Neon free tier (https://neon.tech) — use the "pooled" string.
DATABASE_URL="postgresql://enterprise_user:secure_password@localhost:5432/vms_db"

# --- Redis --------------------------------------------------
# Local: docker-compose Redis
# Prod:  Upstash free tier (https://upstash.com) — rediss:// (TLS)
REDIS_URL="redis://localhost:6379"

# --- API server (NestJS) ------------------------------------
PORT=4000
NODE_ENV=development
JWT_SECRET="your_jwt_secret_key_change_in_production"
CORS_ORIGIN="http://localhost:3000"
PUBLIC_API_URL="http://localhost:4000"
PUBLIC_WEB_URL="http://localhost:3000"

# --- Web (Next.js dashboard) --------------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_BRAND_CODE="vms"

# --- Kiosk --------------------------------------------------
# Same NEXT_PUBLIC_API_URL as above when running locally.

# --- Mobile / Expo ------------------------------------------
# Use these when building from your own Expo / EAS account.
EXPO_PUBLIC_API_URL="http://localhost:4000"
EXPO_OWNER=""
EAS_PROJECT_ID=""

# --- Notifications / email (optional) -----------------------
# Without these the app still runs, but emails / fallback alerts are disabled.
RESEND_API_KEY=""
RESEND_FROM="VMS <onboarding@resend.dev>"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Storage (optional) -------------------------------------
# Default is local disk storage under .storage. Switch to r2 for cloud object storage.
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR=".storage"
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# --- ML / face recognition (optional) -----------------------
CONFIDENCE_THRESHOLD=0.85
