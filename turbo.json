{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["**/.env"],
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_SECRET"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "interactive": true
    },
    "build": {
      "outputs": ["dist/", ".next"],
      "inputs": ["src/**", "package.json"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": [],
      "cache": false
    },
    "db:migrate": {
      "outputs": [],
      "cache": false
    },
    "db:push": {
      "outputs": [],
      "cache": false
    }
  }
}
